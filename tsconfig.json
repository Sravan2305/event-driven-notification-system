{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "isolatedModules": true,

    "verbatimModuleSyntax": true,

    "types": ["node"],

    "outDir": "./dist",

    "rootDir": "./src"
  },

  "include": ["src"]
}